{
  "name": "tx-whatif-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Git-diff for blockchain transactions: replay any tx with what-if overrides (gas, slippage, block delay) on a local Anvil fork.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "anvil": "anvil --fork-url $RPC_URL --steps-tracing",
    "smoke": "node --env-file=.env node_modules/.bin/tsx scripts/smoke.ts"
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4"
  }
}
