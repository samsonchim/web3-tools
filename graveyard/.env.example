# Ethereum mainnet RPC — Alchemy recommended (uses alchemy_getAssetTransfers
# and alchemy_getTokenBalances, both available on the free tier).
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Solana RPC. Defaults to the public endpoint (rate-limited) if unset.
# Use an Alchemy/Helius/QuickNode Solana URL for reliability.
SOLANA_RPC=https://api.mainnet-beta.solana.com
